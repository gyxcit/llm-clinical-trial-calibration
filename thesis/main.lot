\addvspace {10\p@ }
\contentsline {table}{\numberline {4.1}{\ignorespaces The six eligibility labels used in TrialGPT-Criterion-Annotations, organized by criterion type.}}{22}{table.caption.10}%
\contentsline {table}{\numberline {4.2}{\ignorespaces Expert-label distribution in TrialGPT-Criterion-Annotations.}}{23}{table.caption.11}%
\contentsline {table}{\numberline {4.3}{\ignorespaces Selected models and their scientific role in the two-by-two experimental matrix.}}{26}{table.caption.12}%
\contentsline {table}{\numberline {4.4}{\ignorespaces The two-by-two experimental matrix of selected models.}}{27}{table.caption.13}%
\addvspace {10\p@ }
\contentsline {table}{\numberline {5.1}{\ignorespaces Usage-rate ratios of the six labels (GPT-4 vs.\ physician consensus). A ratio of 1.0 indicates balanced usage; ratios far from 1.0 reveal systematic annotation bias.}}{43}{table.caption.14}%
\contentsline {table}{\numberline {5.2}{\ignorespaces Calibration metrics across the twelve configurations. All ECE values exceed the 0.05 threshold, with the lower bound of the 95\% bootstrap confidence interval also strictly above 0.05 in every case. Configurations are grouped by model family.}}{45}{table.caption.15}%
\contentsline {table}{\numberline {5.3}{\ignorespaces Mean overconfidence per configuration. Positive values indicate that the model's mean confidence exceeds its mean accuracy (overconfident); negative values indicate the opposite (underconfident).}}{46}{table.caption.16}%
\contentsline {table}{\numberline {5.4}{\ignorespaces Paired ECE comparison for the four Base--Instruct tests of Hypothesis~H2. $\Delta \textrm {ECE}$ is the difference $\textrm {ECE}(\text {Instruct}) - \textrm {ECE}(\text {Base})$; a positive value supports H2. Permutation p-values are computed with 1{,}000 resamples on the paired data; the Bonferroni-corrected significance threshold across the eight planned comparisons is $\alpha _{\text {corr}} = 0.00625$.}}{48}{table.caption.18}%
\contentsline {table}{\numberline {5.5}{\ignorespaces Mean overconfidence (mean confidence minus mean accuracy) for the four Base--Instruct pairs. Negative values indicate underconfidence, positive values indicate overconfidence. The transition from negative to positive across every pair reveals a consistent effect of RLHF on the direction of the miscalibration.}}{48}{table.caption.19}%
\contentsline {table}{\numberline {5.6}{\ignorespaces Effect of prompt enrichment on ECE. A positive $\Delta \textrm {ECE}$ indicates that Prompt~B, despite being enriched with expert guidance, produces \emph {worse} calibration than the minimal Prompt~A.}}{50}{table.caption.21}%
\contentsline {table}{\numberline {5.7}{\ignorespaces Modal label and its usage rate for each configuration. Configurations with a modal usage above 90\% no longer function as classifiers; they behave as biased constant predictors.}}{52}{table.caption.22}%
\contentsline {table}{\numberline {5.8}{\ignorespaces Ordinal separation (Cliff's $\delta $ on the positive-label probability, inclusion criteria) for the collapsed configurations. A high $\delta $ combined with a near-degenerate predicted-label distribution indicates that the discriminative signal is present but not expressed in the $\arg \max $. Meditron is the sole configuration with a negative $\delta $.}}{55}{table.caption.24}%
\contentsline {table}{\numberline {5.9}{\ignorespaces Global accuracy compared to accuracy on the 238 truly discriminative cases (expert label outside $\{$not excluded, not enough information$\}$). A large negative drop indicates that the model's global accuracy depends on the majority-class distribution rather than on clinical reasoning.}}{58}{table.caption.28}%
\contentsline {table}{\numberline {5.10}{\ignorespaces ECE stratified by criterion type. Ratios above $1$ indicate that calibration is worse on exclusion criteria than on inclusion criteria. {\normalfont \textsc {Meditron}} is the only model to reverse this pattern.}}{59}{table.caption.30}%
\contentsline {table}{\numberline {5.11}{\ignorespaces Usage-rate ratios for the two evasion labels (open-source model over expert). Open-source models over-use ``not enough information'' by factors of 2 to 3.5, while under-using ``not applicable''. This pattern is the mirror image of the GPT-4 bias documented in Section~\ref {sec:res-audit}.}}{61}{table.caption.31}%
\contentsline {table}{\numberline {5.12}{\ignorespaces Concordance index (C-index) for the twelve configurations. No configuration reaches the pre-registered threshold of $0.70$.}}{62}{table.caption.32}%
\contentsline {table}{\numberline {5.13}{\ignorespaces Selective classification test for Hypothesis~H4 (Prompt~A configurations only). $\Delta F_1$ is the difference $F_1(80\%) - F_1(100\%)$; a positive value greater than $0.02$ supports H4.}}{62}{table.caption.33}%
\contentsline {table}{\numberline {5.14}{\ignorespaces ECE before and after post-hoc recalibration, evaluated on the 30\% held-out subset. Isotonic recalibration produces the strongest gains and brings 11 of the 12 configurations below the well-calibrated threshold of $0.05$.}}{64}{table.caption.35}%
\contentsline {table}{\numberline {5.15}{\ignorespaces Cross-validation of isotonic recalibration. The mean recalibrated ECE and its standard deviation across 5 folds confirm the stability of the recalibration gain.}}{65}{table.caption.36}%
\contentsline {table}{\numberline {5.16}{\ignorespaces Re-thresholding on inclusion criteria, evaluated out-of-fold. $F_1^{\arg \max }$ is the macro-F1 of the default $\arg \max $ rule; $F_1^{\text {thr}}$ is the macro-F1 of the cross-validated threshold rule; the gain is reported with a 95\% bootstrap confidence interval. AUC is the area under the ROC curve of the positive-label probability. A gain whose interval excludes zero is significant.}}{66}{table.caption.37}%
\contentsline {table}{\numberline {5.17}{\ignorespaces Two-dimensional diagnostic of the twelve configurations. \emph {Healthy} configurations express their signal ($r \geq 0.6$). \emph {Expressive collapse} configurations have a genuine signal (AUC lower bound $>0.5$) that the $\arg \max $ masks ($r < 0.6$); they are recoverable by re-thresholding. \emph {Corruption} configurations have no usable signal (AUC interval includes or lies below $0.5$) and are not recoverable.}}{70}{table.caption.40}%
\contentsline {table}{\numberline {5.18}{\ignorespaces Empirical coverage and mean set size of conformal prediction at target $\alpha = 0.10$. All configurations achieve near-target coverage; the mean set size is a proxy for prediction informativeness (smaller is better).}}{71}{table.caption.42}%
\contentsline {table}{\numberline {5.19}{\ignorespaces Accuracy stratified by the level of inter-model consensus. Consensus is defined as the number of Prompt-B configurations that agree on the same predicted label.}}{71}{table.caption.43}%
\contentsline {table}{\numberline {5.20}{\ignorespaces Comparison with naïve baselines. Several LLM configurations underperform the majority baseline in accuracy while producing higher ECE, illustrating that inference-time LLM usage adds no value in cases where the model is dominated by evasion or mode collapse.}}{72}{table.caption.44}%
\contentsline {table}{\numberline {5.21}{\ignorespaces Composite utility score across the twelve configurations. The score integrates macro-F1, calibration quality ($1 - \textrm {ECE}$), and prediction diversity (normalized entropy). Configurations with mode collapse receive utility scores close to zero, correctly capturing their lack of practical usefulness \emph {under the default decision rule}.}}{73}{table.caption.45}%
\contentsline {table}{\numberline {5.22}{\ignorespaces External replication on TREC Clinical Trials. The dominant-label rate and the signal/prior ratio $r$ (inclusion criteria) are reported for TrialGPT-Criterion and TREC. The ordering of the configurations and the collapse signature are preserved across the two corpora.}}{74}{table.caption.46}%
\contentsline {table}{\numberline {5.23}{\ignorespaces Outcomes of the four pre-registered hypotheses.}}{76}{table.caption.48}%
\contentsline {table}{\numberline {5.24}{\ignorespaces The twelve original findings documented in this chapter.}}{76}{table.caption.49}%
\addvspace {10\p@ }
\addvspace {10\p@ }
\contentsline {table}{\numberline {A.1}{\ignorespaces Complete calibration metrics for the twelve configurations. The mean confidence and mean accuracy columns reveal the direction of miscalibration (over- or underconfidence).}}{92}{table.caption.52}%
\contentsline {table}{\numberline {A.2}{\ignorespaces Permutation test detailed outputs for Hypothesis~H2. Every test rejects the null hypothesis of equal calibration between Base and Instruct at the Bonferroni-corrected level.}}{93}{table.caption.53}%
\contentsline {table}{\numberline {A.3}{\ignorespaces Stratified ECE by criterion type with bootstrap confidence intervals. Ten of twelve configurations show a ratio $\textrm {ECE}_{\text {excl}} / \textrm {ECE}_{\text {incl}} > 2.0$.}}{93}{table.caption.54}%
\contentsline {table}{\numberline {A.4}{\ignorespaces Post-hoc recalibration comparison: absolute ECE values and relative ECE reduction (as a percentage of the original ECE). Isotonic regression is the strongest method for all twelve configurations.}}{94}{table.caption.55}%
\contentsline {table}{\numberline {A.5}{\ignorespaces Per-fold ECE after isotonic recalibration, and mean $\pm $ standard deviation across five folds.}}{94}{table.caption.56}%
\contentsline {table}{\numberline {A.6}{\ignorespaces Conformal prediction detailed results across the twelve configurations at target coverage $0.90$. Singletons denote prediction sets of size~1 (unique predicted label).}}{95}{table.caption.57}%
\contentsline {table}{\numberline {A.7}{\ignorespaces Composite utility score components for the twelve configurations. The composite utility is the product of the three columns preceding it.}}{95}{table.caption.58}%
\contentsline {table}{\numberline {A.8}{\ignorespaces Re-thresholding on exclusion criteria, evaluated out-of-fold. The exclusion stratum has only ten gold-positive cases; the wide confidence intervals and high threshold variance ($\sigma _t$) reflect this limited support. Reported for completeness only.}}{96}{table.caption.59}%
