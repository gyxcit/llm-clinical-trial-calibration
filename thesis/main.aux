\@writefile{toc}{\contentsline {subsection}{\numberline {5.12.1}Out-of-fold Re-thresholding Gains}{66}{subsection.5.12.1}\protected@file@percent }
\newlabel{subsec:res-rethreshold-gains}{{5.12.1}{66}{Out-of-fold Re-thresholding Gains}{subsection.5.12.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.16}{\ignorespaces Re-thresholding on inclusion criteria, evaluated out-of-fold. $F_1^{\arg \max }$ is the macro-F1 of the default $\arg \max $ rule; $F_1^{\text  {thr}}$ is the macro-F1 of the cross-validated threshold rule; the gain is reported with a 95\% bootstrap confidence interval. AUC is the area under the ROC curve of the positive-label probability. A gain whose interval excludes zero is significant.}}{66}{table.caption.37}\protected@file@percent }
\newlabel{tab:res-rethreshold}{{5.16}{66}{Re-thresholding on inclusion criteria, evaluated out-of-fold. $F_1^{\arg \max }$ is the macro-F1 of the default $\arg \max $ rule; $F_1^{\text {thr}}$ is the macro-F1 of the cross-validated threshold rule; the gain is reported with a 95\% bootstrap confidence interval. AUC is the area under the ROC curve of the positive-label probability. A gain whose interval excludes zero is significant}{table.caption.37}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.5}{\ignorespaces Macro-F1 before and after re-thresholding on inclusion criteria, evaluated out-of-fold. Each configuration is drawn as a segment running from its $\arg \max $ macro-F1 (hollow marker) to its re-thresholded macro-F1 (filled marker), with the 95\% bootstrap interval of the gain. Colours follow the diagnostic regimes of Figure~\ref {fig:res-quadrant}. The four expressive-collapse configurations move from zero to between $0.62$ and $0.79$; the healthy configurations barely move, which is the negative control. The corruption configurations also move, but Section~\ref {subsec:res-rethreshold-diag} shows this movement to be an artefact of class imbalance rather than a genuine recovery.}}{67}{figure.caption.38}\protected@file@percent }
\newlabel{fig:res-rethreshold}{{5.5}{67}{Macro-F1 before and after re-thresholding on inclusion criteria, evaluated out-of-fold. Each configuration is drawn as a segment running from its $\arg \max $ macro-F1 (hollow marker) to its re-thresholded macro-F1 (filled marker), with the 95\% bootstrap interval of the gain. Colours follow the diagnostic regimes of Figure~\ref {fig:res-quadrant}. The four expressive-collapse configurations move from zero to between $0.62$ and $0.79$; the healthy configurations barely move, which is the negative control. The corruption configurations also move, but Section~\ref {subsec:res-rethreshold-diag} shows this movement to be an artefact of class imbalance rather than a genuine recovery}{figure.caption.38}{}}
\@writefile{toc}{\contentsline {paragraph}{Stability of the fitted threshold.}{67}{paragraph*.39}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.12.2}A Two-Dimensional Diagnostic: Collapse Versus Corruption}{68}{subsection.5.12.2}\protected@file@percent }
\newlabel{subsec:res-rethreshold-diag}{{5.12.2}{68}{A Two-Dimensional Diagnostic: Collapse Versus Corruption}{subsection.5.12.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.6}{\ignorespaces Two-dimensional diagnostic of the twelve configurations. The horizontal axis is the signal-to-prior ratio $r$ (log scale), which measures whether a configuration expresses its decision; the vertical axis is the area under the ROC curve of the positive-label probability, which measures whether a discriminative signal is present. Error bars are 95\% bootstrap confidence intervals on the AUC. The dashed lines mark the collapse threshold ($r \approx 0.6$) and the chance level (AUC $= 0.5$). The three shaded regions correspond to the three regimes: healthy configurations, expressive collapse (recoverable by re-thresholding), and signal corruption (irrecoverable). Llama-Instruct~A occupies the upper-left corner: the highest discriminative signal of the study, entirely unexpressed by its $\arg \max $.}}{69}{figure.caption.41}\protected@file@percent }
\newlabel{fig:res-quadrant}{{5.6}{69}{Two-dimensional diagnostic of the twelve configurations. The horizontal axis is the signal-to-prior ratio $r$ (log scale), which measures whether a configuration expresses its decision; the vertical axis is the area under the ROC curve of the positive-label probability, which measures whether a discriminative signal is present. Error bars are 95\% bootstrap confidence intervals on the AUC. The dashed lines mark the collapse threshold ($r \approx 0.6$) and the chance level (AUC $= 0.5$). The three shaded regions correspond to the three regimes: healthy configurations, expressive collapse (recoverable by re-thresholding), and signal corruption (irrecoverable). Llama-Instruct~A occupies the upper-left corner: the highest discriminative signal of the study, entirely unexpressed by its $\arg \max $}{figure.caption.41}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.17}{\ignorespaces Two-dimensional diagnostic of the twelve configurations. \emph  {Healthy} configurations express their signal ($r \geq 0.6$). \emph  {Expressive collapse} configurations have a genuine signal (AUC lower bound $>0.5$) that the $\arg \max $ masks ($r < 0.6$); they are recoverable by re-thresholding. \emph  {Corruption} configurations have no usable signal (AUC interval includes or lies below $0.5$) and are not recoverable.}}{70}{table.caption.40}\protected@file@percent }
\newlabel{tab:res-diagnostic}{{5.17}{70}{Two-dimensional diagnostic of the twelve configurations. \emph {Healthy} configurations express their signal ($r \geq 0.6$). \emph {Expressive collapse} configurations have a genuine signal (AUC lower bound $>0.5$) that the $\arg \max $ masks ($r < 0.6$); they are recoverable by re-thresholding. \emph {Corruption} configurations have no usable signal (AUC interval includes or lies below $0.5$) and are not recoverable}{table.caption.40}{}}
