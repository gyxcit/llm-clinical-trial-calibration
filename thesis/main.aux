\@writefile{lot}{\contentsline {table}{\numberline {5.13}{\ignorespaces ECE before and after post-hoc recalibration, evaluated on the 30\% held-out subset. Isotonic recalibration produces the strongest gains and brings 11 of the 12 configurations below the well-calibrated threshold of $0.05$.}}{57}{table.caption.28}\protected@file@percent }
\newlabel{tab:res-recalibration}{{5.13}{57}{ECE before and after post-hoc recalibration, evaluated on the 30\% held-out subset. Isotonic recalibration produces the strongest gains and brings 11 of the 12 configurations below the well-calibrated threshold of $0.05$}{table.caption.28}{}}
